# Copy to .env and fill in values.
# These are loaded by hardhat.config.ts via dotenv.

# Required for deployment
PRIVATE_KEY=0xyour_wallet_private_key_here

# RPC endpoint for Base Sepolia (optional — defaults to https://sepolia.base.org)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Required for contract verification on Basescan (optional)
BASESCAN_API_KEY=your_basescan_api_key_here

# Set this to wire up your existing insurance contract after deployment
INSURANCE_CONTRACT_ADDRESS=

# Soft minimum reserve in ETH (default: 0.1)
MINIMUM_RESERVE_ETH=0.1
